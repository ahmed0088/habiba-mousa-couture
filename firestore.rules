rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isStaff() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    function isAdmin() {
      return isStaff() &&
        get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'admin';
    }

    // Anyone can view active products; only staff can create/edit/delete
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Seasonal collections grouping products; same access shape as products
    match /collections/{collectionId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Managed garment-type categories (Dress, Abaya, Pants, ...) — same access shape
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Promotional videos (YouTube/Vimeo links) shown in the public gallery — same access shape
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Site-wide business settings (contact info, maps, deposit %, hero/about copy)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Anyone can submit a request (optionally tied to their own account via clientUid);
    // staff can read/update everything, a signed-in client can read only their own requests.
    match /requests/{requestId} {
      // Public create: anonymous or signed-in as the request's own owner. Status
      // and finalAmount are staff-only administrative fields and can never be
      // set from the public form; any URL fields must be http(s) links, not
      // javascript:/data: URIs that could execute if a staff member later
      // clicks them in the admin dashboard.
      allow create: if (request.resource.data.clientUid == null
                        || request.resource.data.clientUid == request.auth.uid)
                    && request.resource.data.status == 'new'
                    && !('finalAmount' in request.resource.data)
                    && (!('clientLocationUrl' in request.resource.data)
                        || request.resource.data.clientLocationUrl == null
                        || request.resource.data.clientLocationUrl.matches('^https://.*'))
                    && (!('referenceImageUrl' in request.resource.data)
                        || request.resource.data.referenceImageUrl == null
                        || request.resource.data.referenceImageUrl.matches('^https?://.*'));

      allow read: if isStaff()
                  || (request.auth != null && resource.data.clientUid == request.auth.uid);

      // Staff can update anything. A signed-in client can edit or cancel only
      // their own request, and only while it's still 'new' or 'contacted'
      // (before real work starts, matching the cancellation policy on the
      // Terms page) — limited to the fields a client would legitimately want
      // to fix (contact/shipping/notes/design details), never the piece it's
      // for, its order/cart identifiers, or staff-owned fields like
      // finalAmount or any status past 'cancelled'.
      allow update: if isStaff()
                    || (request.auth != null
                        && resource.data.clientUid == request.auth.uid
                        && resource.data.status in ['new', 'contacted']
                        && request.resource.data.status in ['new', 'contacted', 'cancelled']
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                            'clientName', 'clientPhone', 'clientAddress', 'clientLocationUrl',
                            'recipientName', 'recipientPhone', 'recipientAddress',
                            'material', 'preferredDate', 'notes',
                            'designDescription', 'referenceImageUrl', 'status'
                          ])
                        && (!('clientLocationUrl' in request.resource.data)
                            || request.resource.data.clientLocationUrl == null
                            || request.resource.data.clientLocationUrl.matches('^https://.*'))
                        && (!('referenceImageUrl' in request.resource.data)
                            || request.resource.data.referenceImageUrl == null
                            || request.resource.data.referenceImageUrl.matches('^https?://.*')));

      allow delete: if isStaff();
    }

    // Client profiles (name/email/phone captured at signup) — a client manages only their own;
    // staff can read them for reference (e.g. matching a request to a phone number).
    match /clients/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isStaff();
    }

    // Log of staff actions — any staff member's actions get logged, but only
    // admins can read the history back or clean up entries.
    match /activityLog/{docId} {
      allow create: if isStaff();
      allow read, delete: if isAdmin();
    }

    // Staff roster — admins can manage anyone, staff can read the roster and
    // update their own name (but not their own role or email, to prevent
    // self-escalation or breaking the Auth-UID email match).
    match /staff/{staffUid} {
      allow read: if isStaff();
      allow write: if isAdmin();
      allow update: if request.auth != null && request.auth.uid == staffUid
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.email == resource.data.email;
    }

    // Pending staff invites (email-keyed, reconciled manually to a UID) — admin only
    match /staff_pending/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
